#!/bin/sh
# /opt/bin/vpn — control the mihomo VPN on Keenetic (the analog of the old `spd`).
#
#   vpn start|stop|restart        start/stop the VPN (+ monit supervision)
#   vpn status                    process, TUN, routing, current server, sub, UI
#   vpn sub "<url>"               set a new subscription URL and reload
#   vpn reload                    reload config + refresh subscription (no restart)
#   vpn servers                   list available servers
#   vpn select "<name>"           switch to a specific server (manual, #5)
#   vpn auto                      switch group to AUTO (first healthy server)
#   vpn log [N]                   tail the mihomo log

DIR=/opt/etc/mihomo
CONFIG=$DIR/config.yaml
API=http://127.0.0.1:9090
INIT=/opt/etc/init.d/S06mihomo
PIDFILE=/opt/var/run/mihomo.pid
LOG=/opt/var/log/mihomo.log
GROUP=PROXY

has_monit() { command -v monit >/dev/null 2>&1 && monit summary 2>/dev/null | grep -qi mihomo; }
is_running() { [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; }

# tiny JSON value extractor: json_get '<key>' < json
json_get() { sed -n "s/.*\"$1\":\"\([^\"]*\)\".*/\1/p" | head -1; }

cmd_status() {
    echo "=== mihomo ==="
    if is_running; then echo "  RUNNING (PID $(cat "$PIDFILE"))"; else echo "  STOPPED"; fi
    has_monit && echo "  monit: supervised"

    echo "=== TUN ==="
    ip -o link show mihomo0 2>/dev/null | sed 's/^/  /' || echo "  mihomo0: down"

    echo "=== routing (EJX policy -> VPN) ==="
    /opt/bin/mihomo-route status 2>/dev/null | sed 's/^/  /'

    echo "=== current server ==="
    now=$(curl -fsS "$API/proxies/$GROUP" 2>/dev/null | json_get now)
    echo "  $GROUP -> ${now:-<api unavailable>}"

    echo "=== subscription ==="
    url=$(sed -n 's/.*url:[[:space:]]*"\{0,1\}\([^"]*\)"\{0,1\}[[:space:]]*#sub.*/\1/p' "$CONFIG")
    echo "  url: ${url:-<not set>}"
    prov=$(curl -fsS "$API/providers/proxies/airport" 2>/dev/null)
    if [ -n "$prov" ]; then
        n=$(echo "$prov" | grep -o '"name":' | wc -l)
        echo "  servers loaded: $((n>0?n-1:0))"
    fi

    echo "=== web UI ==="
    echo "  http://192.168.1.1:9090/ui"
}

case "${1:-}" in
    start)
        "$INIT" start
        has_monit && monit monitor mihomo 2>/dev/null
        ;;
    stop)
        has_monit && monit unmonitor mihomo 2>/dev/null
        "$INIT" stop
        ;;
    restart)
        has_monit && monit unmonitor mihomo 2>/dev/null
        "$INIT" restart
        has_monit && monit monitor mihomo 2>/dev/null
        ;;
    status)
        cmd_status
        ;;
    sub)
        [ -z "${2:-}" ] && { echo "usage: vpn sub \"<subscription-url>\""; exit 1; }
        # Only touch the line carrying the #sub marker (not the health-check url).
        sed -i "s#^\([[:space:]]*url:\).*#sub.*#\1 \"$2\"  #sub#" "$CONFIG"
        echo "subscription url updated"
        "$0" reload
        ;;
    reload)
        curl -fsS -X PUT "$API/configs?force=true" \
             -H 'Content-Type: application/json' \
             -d "{\"path\":\"$CONFIG\"}" >/dev/null 2>&1
        curl -fsS -X PUT "$API/providers/proxies/airport" >/dev/null 2>&1
        echo "config reloaded + subscription refreshed"
        ;;
    servers|list)
        if command -v jq >/dev/null 2>&1; then
            curl -fsS "$API/proxies/$GROUP" | jq -r '.all[]'
        else
            curl -fsS "$API/proxies/$GROUP" \
                | grep -o '"all":\[[^]]*\]' \
                | sed 's/.*\[//; s/\]//; s/","/\n/g; s/"//g'
        fi
        ;;
    select|use)
        [ -z "${2:-}" ] && { echo "usage: vpn select \"<server-name>\""; exit 1; }
        if curl -fsS -X PUT "$API/proxies/$GROUP" \
            -H 'Content-Type: application/json' \
            -d "{\"name\":\"$2\"}" >/dev/null 2>&1; then
            echo "selected: $2"
        else
            echo "failed — check the exact name with: vpn servers"
        fi
        ;;
    auto)
        curl -fsS -X PUT "$API/proxies/$GROUP" \
            -H 'Content-Type: application/json' -d '{"name":"AUTO"}' >/dev/null 2>&1 \
            && echo "switched to AUTO"
        ;;
    log)
        tail -n "${2:-40}" "$LOG"
        ;;
    *)
        echo "vpn start|stop|restart|status|sub \"<url>\"|reload|servers|select \"<name>\"|auto|log [N]"
        ;;
esac
