#!/bin/sh
# /opt/etc/init.d/S06mihomo — Entware boot autostart for the mihomo VPN.
# Thin shim: all logic lives in /opt/bin/te-vpn ('up'/'down' = daemon control
# without monit calls; monit adopts the process on its own via mihomo.conf).

case "${1:-}" in
    start)   /opt/bin/te-vpn up ;;
    stop)    /opt/bin/te-vpn down ;;
    restart) /opt/bin/te-vpn down; sleep 2; /opt/bin/te-vpn up ;;
    status)  /opt/bin/te-vpn status ;;
    *) echo "usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
