#!/bin/sh
# /opt/etc/init.d/S06mihomo — Entware init for the mihomo VPN.
# Started at boot by rc.unslung (any executable S* script) and by monit.
# Naming: S06 = right after spider's old S05 slot (spider is disabled).

BIN=/opt/sbin/mihomo
DIR=/opt/etc/mihomo
PIDFILE=/opt/var/run/mihomo.pid
LOGFILE=/opt/var/log/mihomo.log
API=http://127.0.0.1:9090
PATH=/opt/sbin:/opt/bin:/usr/sbin:/usr/bin:/sbin:/bin
export PATH

# Ignore HUP so an SSH disconnect can't kill us mid start/stop.
trap '' HUP

is_running() {
    [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null && return 0
    pidof mihomo >/dev/null 2>&1
}

start() {
    is_running && { echo "mihomo already running"; return 0; }
    mkdir -p /opt/var/run /opt/var/log
    ulimit -SHn 65535
    echo "Starting mihomo..."
    start-stop-daemon -S -b -m -p "$PIDFILE" -x "$BIN" -- -d "$DIR" >>"$LOGFILE" 2>&1
    # wait for the controller API to answer (max 15s)
    i=0
    while [ "$i" -lt 15 ]; do
        curl -fsS "$API/version" >/dev/null 2>&1 && break
        sleep 1; i=$((i + 1))
    done
    /opt/bin/mihomo-route add
    if is_running; then
        echo "mihomo started (PID $(cat "$PIDFILE" 2>/dev/null))"
    else
        echo "mihomo FAILED to start — see $LOGFILE"
        return 1
    fi
}

stop() {
    echo "Stopping mihomo..."
    /opt/bin/mihomo-route del
    [ -f "$PIDFILE" ] && kill "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null
    sleep 1
    pkill -KILL -f "$BIN -d $DIR" 2>/dev/null
    rm -f "$PIDFILE"
    echo "mihomo stopped"
}

case "${1:-}" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 2; start ;;
    status)
        is_running && echo "running (PID $(cat "$PIDFILE" 2>/dev/null))" || echo "stopped"
        ;;
    *) echo "usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
